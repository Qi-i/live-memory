{
  "name": "live-memory",
  "private": true,
  "version": "2.1.4",
  "description": "以海报、票根、座位图和现场照片为核心的私人演出档案",
  "author": "Zhiqi Liu",
  "license": "MIT",
  "keywords": [
    "concert",
    "ticket",
    "archive",
    "pwa",
    "supabase",
    "github-pages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Qi-i/live-memory.git"
  },
  "homepage": "https://qi-i.github.io/live-memory/",
  "bugs": {
    "url": "https://github.com/Qi-i/live-memory/issues"
  },
  "type": "module",
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=20.19"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "scripts": {
    "dev": "vite --configLoader runner --host 0.0.0.0 --port 5173",
    "dev:local": "vite --configLoader runner --host 127.0.0.1 --port 5173",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build --configLoader runner",
    "test": "node ./scripts/run-tests.mjs",
    "check": "npm run test && npm run build",
    "preview": "vite preview --configLoader runner --host 0.0.0.0 --port 5174"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.53.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  }
}
